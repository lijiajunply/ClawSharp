<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ClawSharp.Desktop.ViewModels"
             xmlns:rt="using:ClawSharp.Lib.Runtime"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             xmlns:infra="clr-namespace:ClawSharp.Desktop.Infrastructure"
             xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
             xmlns:material="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ClawSharp.Desktop.Views.ChatView"
             x:DataType="vm:ChatViewModel">
    <Grid ColumnDefinitions="320,*">
        <!-- Sidebar: ThreadSpace & Session History -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource SukiBorderBrush}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- ThreadSpace Selector -->
                <suki:GlassCard Grid.Row="0" Margin="10" Padding="10">
                    <StackPanel Spacing="5">
                        <TextBlock Text="ThreadSpace" FontSize="12" FontWeight="Bold" Opacity="0.6" />
                        <ComboBox ItemsSource="{Binding ThreadSpaces}" 
                                  SelectedItem="{Binding CurrentThreadSpace}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="rt:ThreadSpaceRecord">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" />
                                        <TextBlock Text="(Global)" IsVisible="{Binding IsGlobal}" FontSize="10" Opacity="0.5" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </suki:GlassCard>

                <!-- Session History -->
                <Grid Grid.Row="1" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Recent Sessions" FontSize="12" FontWeight="Bold" Opacity="0.6" Margin="15,10,15,5" />
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding RecentSessions}" 
                             SelectedItem="{Binding SelectedSession}"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="2" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="rt:SessionRecord">
                                <Grid ColumnDefinitions="Auto,*" Margin="8,5">
                                    <material:MaterialIcon Grid.Column="0" Kind="MessageOutline" Width="18" Height="18" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AgentId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding StartedAt, StringFormat='{}{0:MM-dd HH:mm}'}" FontSize="10" Opacity="0.5" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Bottom Controls: New Chat & Agent Selection -->
                <suki:GlassCard Grid.Row="2" Margin="10" Padding="10">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Agent" FontSize="12" FontWeight="Bold" Opacity="0.6" Margin="2,0" />
                        <ComboBox ItemsSource="{Binding Agents}" 
                                  SelectedItem="{Binding CurrentAgent}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:AgentViewModel">
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Command="{Binding NewChatCommand}" 
                                Content="New Chat" 
                                Classes="Primary"
                                HorizontalAlignment="Stretch" />
                    </StackPanel>
                </suki:GlassCard>
            </Grid>
        </Border>

        <!-- Main Chat Area -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto">
            <!-- Messages Area -->
            <ScrollViewer Grid.Row="0" Name="ChatScrollViewer">
                <ItemsControl ItemsSource="{Binding Messages}" Margin="20,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageViewModel">
                            <Grid HorizontalAlignment="{Binding IsAi, Converter={StaticResource AiAlignmentConverter}}">
                                <suki:GlassCard Margin="0,10" Padding="15" 
                                               MaxWidth="900" 
                                               CornerRadius="12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Sender}" 
                                                   FontSize="11" 
                                                   FontWeight="Bold" 
                                                   Opacity="0.5" 
                                                   HorizontalAlignment="{Binding IsAi, Converter={StaticResource AiAlignmentConverter}}" />
                                                   <md:MarkdownRenderer MarkdownBuilder="{Binding MarkdownBuilder}" />
                                                   </StackPanel>                                </suki:GlassCard>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input Area -->
            <suki:GlassCard Grid.Row="1" Margin="20,10,20,20">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Text="{Binding InputText}" 
                             Watermark="Type a message..."
                             AcceptsReturn="True"
                             IsEnabled="{Binding !IsProcessing}"
                             Classes="Flat"
                             BorderThickness="0"
                             Margin="0,0,10,0"
                             MaxHeight="200"
                             TextWrapping="Wrap">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SendMessageCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>
                    <Button Grid.Column="1" 
                            Command="{Binding SendMessageCommand}"
                            Content="Send"
                            Classes="Primary"
                            VerticalAlignment="Bottom" />
                </Grid>
            </suki:GlassCard>
        </Grid>
    </Grid>

    <UserControl.Resources>
        <infra:AiAlignmentConverter x:Key="AiAlignmentConverter" />
    </UserControl.Resources>
</UserControl>
