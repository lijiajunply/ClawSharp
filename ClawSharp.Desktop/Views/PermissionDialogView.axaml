<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ClawSharp.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
        x:Class="ClawSharp.Desktop.Views.PermissionDialogView"
        x:DataType="views:PermissionDialogView"
        Title="{Binding DialogTitle}"
        Width="450" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SystemDecorations="BorderOnly"
        Background="#2D2D30">

    <Border BorderBrush="#3E3E42" BorderThickness="1" CornerRadius="8">
        <Grid RowDefinitions="Auto,*,Auto" Margin="20">
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15" />
            
            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#CCCCCC" />
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
                <Button Content="Deny" Click="OnDenyClick" Background="#4A4A4F" Foreground="White" Width="80" HorizontalContentAlignment="Center" />
                <Button Content="Allow" Click="OnAllowClick" Background="#007ACC" Foreground="White" Width="80" HorizontalContentAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>